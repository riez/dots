{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "Metis (Plan Consultant)": {
      "model": "anthropic/claude-opus-4-7",
      "reasoningEffort": "max"
    },
    "Momus (Plan Reviewer)": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh"
    },
    "Prometheus (Planner)": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "high"
    },
    "Sisyphus": {
      "model": "anthropic/claude-opus-4-7",
      "reasoningEffort": "max"
    },
    "Sisyphus-Junior": {
      "model": "anthropic/claude-opus-4-7",
      "reasoningEffort": "max"
    },
    "debugger": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh"
    },
    "document-writer": {
      "model": "anthropic/claude-opus-4-7",
      "reasoningEffort": "max"
    },
    "explore": {
      "model": "anthropic/claude-sonnet-4-6",
      "reasoningEffort": "max"
    },
    "frontend-ui-ux-engineer": {
      "model": "anthropic/claude-opus-4-7",
      "reasoningEffort": "max"
    },
    "librarian": {
      "model": "anthropic/claude-opus-4-7",
      "reasoningEffort": "max"
    },
    "multimodal-looker": {
      "model": "anthropic/claude-opus-4-7",
      "reasoningEffort": "max"
    },
    "oracle": {
      "model": "anthropic/claude-opus-4-7",
      "reasoningEffort": "max"
    },
    "orchestrator-sisyphus": {
      "model": "anthropic/claude-opus-4-7",
      "permission": {
        "task": "allow"
      },
      "reasoningEffort": "max"
    },
    "superpowers:bart": {
      "model": "anthropic/claude-opus-4-7",
      "reasoningEffort": "max"
    },
    "superpowers:code-explorer": {
      "model": "anthropic/claude-sonnet-4-6",
      "reasoningEffort": "max"
    },
    "superpowers:code-implementer": {
      "model": "openai/gpt-5.3-codex",
      "reasoningEffort": "high"
    },
    "superpowers:code-reviewer": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "xhigh"
    },
    "superpowers:homer": {
      "model": "openai/gpt-5.5",
      "reasoningEffort": "medium"
    },
    "superpowers:lisa": {
      "model": "anthropic/claude-opus-4-7",
      "reasoningEffort": "max"
    },
    "superpowers:marge": {
      "model": "anthropic/claude-opus-4-7",
      "reasoningEffort": "max"
    },
    "superpowers:orchestrator": {
      "mode": "all",
      "model": "anthropic/claude-opus-4-7",
      "permission": {
        "task": "allow"
      },
      "reasoningEffort": "max"
    },
    "superpowers:ralph": {
      "model": "anthropic/claude-opus-4-7",
      "reasoningEffort": "max"
    },
    "superpowers:ui-ux-peer": {
      "model": "anthropic/claude-opus-4-7",
      "reasoningEffort": "max"
    },
    "superpowers:ux-researcher": {
      "model": "anthropic/claude-opus-4-7",
      "reasoningEffort": "max"
    }
  },
  "default_agent": "superpowers:orchestrator",
  "disabled_providers": [
    "opencode"
  ],
  "enabled_providers": [
    "openai",
    "google",
    "zai-coding-plan",
    "anthropic"
  ],
  "mcp": {
    "chrome-devtools": {
      "command": [
        "npx",
        "-y",
        "chrome-devtools-mcp@latest"
      ],
      "timeout": 20000,
      "type": "local"
    },
    "figma": {
      "command": [
        "npx",
        "-y",
        "figma-developer-mcp",
        "--stdio"
      ],
      "environment": {
        "FIGMA_API_KEY": "__FIGMA_API_KEY__"
      },
      "timeout": 30000,
      "type": "local"
    },
    "greptile": {
      "headers": {
        "Authorization": "Bearer __GREPTILE_API_KEY__"
      },
      "type": "remote",
      "url": "https://api.greptile.com/mcp"
    },
    "next-devtools": {
      "command": [
        "npx",
        "-y",
        "next-devtools-mcp@0.2.0"
      ],
      "timeout": 20000,
      "type": "local"
    },
    "pal": {
      "command": [
        "__HOME__/Code/github/BeehiveInnovations/pal-mcp-server/pal-mcp-server"
      ],
      "enabled": true,
      "timeout": 120000,
      "type": "local"
    },
    "playwright": {
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "timeout": 20000,
      "type": "local"
    },
    "sonarqube": {
      "command": [
        "npx",
        "-y",
        "oe-sonar-mcp"
      ],
      "environment": {
        "SONARQUBE_URL": "__SONARQUBE_URL__",
        "SONARQUBE_TOKEN": "__SONARQUBE_TOKEN__"
      },
      "enabled": true,
      "timeout": 60000,
      "type": "local"
    },
    "crawl4ai": {
      "type": "remote",
      "url": "https://crawl4ai-local.taila7050b.ts.net",
      "enabled": true,
      "timeout": 30000
    },
    "svelte-mcp": {
      "command": [
        "npx",
        "-y",
        "@sveltejs/mcp@latest"
      ],
      "timeout": 20000,
      "type": "local"
    },
    "codex": {
      "command": [
        "/opt/homebrew/bin/codex",
        "-m",
        "gpt-5.5",
        "-c",
        "model_reasoning_effort=high",
        "mcp-server"
      ],
      "timeout": 120000,
      "type": "local"
    },
    "pencil": {
      "command": [
        "__PENCIL_MCP_BINARY__",
        "--app",
        "desktop"
      ],
      "enabled": true,
      "type": "local"
    }
  },
  "model": "openai/gpt-5.5",
  "plugin": [
    "opencode-openai-codex-auth",
    "@franlol/opencode-md-table-formatter@0.0.3",
    "opencode-antigravity-auth@beta"
  ],
  "provider": {
    "google": {
      "models": {
        "claude-opus-4-7-thinking": {
          "limit": {
            "context": 200000,
            "output": 64000
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          },
          "name": "Claude Opus 4.7 Thinking (Antigravity)"
        },
        "claude-sonnet-4-6": {
