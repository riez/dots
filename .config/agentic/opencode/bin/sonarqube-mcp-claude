#!/usr/bin/env bash
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:$PATH"

ENV_FILE="$HOME/Code/github/riez/local-infrastructure/.env"
if [[ -f "$ENV_FILE" ]]; then
  set -a
  source "$ENV_FILE" 2>/dev/null || true
  set +a
fi

TOKEN="${SONARQUBE_TOKEN:-}"
if [[ -z "$TOKEN" ]]; then
  exit 1
fi

SQ_URL="https://sonarqube-local.${TAILNET:-taila7050b}.ts.net"
export SONARQUBE_URL="${SQ_URL}"
export SONARQUBE_TOKEN="${TOKEN}"

/opt/homebrew/bin/docker run -i --rm \
  -e SONARQUBE_URL \
  -e SONARQUBE_TOKEN \
  mcp/sonarqube 2>/dev/null | /usr/bin/grep --line-buffered -E '^[{\[]'
