#!/usr/bin/env bash
set -euo pipefail

SONARQUBE_URL="https://sonarqube-local.taila7050b.ts.net"
SONARQUBE_IDE_PORT="64124"

# Store the token in macOS Keychain under this service name:
#   opencode-sonarqube-token
TOKEN=""
if command -v security >/dev/null 2>&1; then
  TOKEN="$(security find-generic-password -s opencode-sonarqube-token -w 2>/dev/null || true)"
fi

if [ -z "${TOKEN}" ]; then
  echo "sonarqube-mcp: missing token" >&2
  echo "Add it to Keychain with:" >&2
  echo "  security add-generic-password -a \"$USER\" -s opencode-sonarqube-token -w '<TOKEN>' -U" >&2
  exit 1
fi

export SONARQUBE_URL
export SONARQUBE_IDE_PORT
export SONARQUBE_TOKEN="${TOKEN}"

STATUS_JSON=""
STATUS=""
VERSION=""
if command -v curl >/dev/null 2>&1; then
  STATUS_JSON="$(curl -fsSL "${SONARQUBE_URL}/api/system/status" 2>/dev/null || true)"
fi

if [ -n "${STATUS_JSON}" ] && command -v python3 >/dev/null 2>&1; then
  STATUS="$(python3 -c 'import json,sys; d=json.loads(sys.stdin.read()); print(d.get("status", ""))' <<<"$STATUS_JSON" 2>/dev/null || true)"
  VERSION="$(python3 -c 'import json,sys; d=json.loads(sys.stdin.read()); print(d.get("version", ""))' <<<"$STATUS_JSON" 2>/dev/null || true)"
fi

if [ -n "${STATUS}" ] && [ "${STATUS}" != "UP" ]; then
  echo "sonarqube-mcp: SonarQube is not UP (status=${STATUS} version=${VERSION})" >&2
  echo "Fix SonarQube first (finish DB migration / leave safe mode), then retry." >&2
  exit 2
fi

# Filter out Docker certificate installation messages from stdout
# MCP uses JSON-RPC so we only pass through lines starting with { or [
docker run -i --rm \
  -e SONARQUBE_URL \
  -e SONARQUBE_IDE_PORT \
  -e SONARQUBE_TOKEN \
  mcp/sonarqube 2>/dev/null | grep --line-buffered -E '^[{\[]'
